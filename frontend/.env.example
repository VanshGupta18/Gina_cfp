# Copy to .env.local for local development. Never commit .env.local.

# Backend API base (no trailing slash) — must match backend PORT (default 3001)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Supabase — same project as backend SUPABASE_URL (anon key for browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Optional: canonical public URL (no trailing slash). Used for server-only fallbacks.
# On Vercel, OAuth uses the browser origin; set this if you rely on server-side URL building.
# Must match entries in Supabase → Authentication → URL Configuration → Redirect URLs
# e.g. https://your-app.vercel.app/auth/callback and https://your-domain.com/auth/callback
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
