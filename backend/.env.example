# Copy to .env and fill values. See docs/Backend_Master.md §2.
# Never commit .env.

# PostgreSQL (Supabase — transaction pooler URI recommended; user + password in URL)
# npm run migrate loads backend/.env — a shell-only $DATABASE_URL is not set for npm scripts
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase — JWT verification + server client
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# AWS S3 — dataset uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=talktodata-uploads
AWS_REGION=eu-west-2

# Hugging Face — SQL tier + embeddings (second key optional)
HF_API_KEY_1=hf_
HF_API_KEY_2=
SQLCODER_HF_MODEL=defog/sqlcoder-8b
EMBEDDING_HF_MODEL=BAAI/bge-small-en-v1.5

# Groq — planner, narrator, SQL fallback (extra keys optional)
GROQ_API_KEY_1=gsk_
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_MODEL_PLANNER=llama-4-scout-17b-16e-instruct
GROQ_MODEL_NARRATOR=llama-4-maverick-17b-128e-instruct
GROQ_MODEL_SQL_FALLBACK=llama-4-maverick-17b-128e-instruct

# Google Gemini — optional narrator; second key optional
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_MODEL=gemini-2.5-flash

# Pipeline
USE_GEMINI_NARRATOR=false
SQL_TIER_LOG=false
SNAPSHOT_MODE=false
SQL_FALLBACK_TIMEOUT_MS=3000
SECONDARY_QUERY_DELTA_THRESHOLD=0.05

# Server
PORT=3001
NODE_ENV=development

# CORS: optional comma-separated production origins (e.g. Vercel). Localhost and 127.0.0.1 dev ports are allowed by default.
# CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=
