# Copy to .env and fill values. See docs/Backend_Master.md §2.
# Never commit .env.

# PostgreSQL (Supabase — transaction pooler URI recommended; user + password in URL)
# npm run migrate loads backend/.env — a shell-only $DATABASE_URL is not set for npm scripts
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase — JWT verification + server client
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# AWS S3 — dataset uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-south-1

# Hugging Face — SQL tier + embeddings (second key optional)
HF_API_KEY_1=hf_
HF_API_KEY_2=
SQLCODER_HF_MODEL=defog/llama-3-sqlcoder-8b
EMBEDDING_HF_MODEL=BAAI/bge-small-en-v1.5

# Groq — planner, narrator, SQL fallback (extra keys optional)
GROQ_API_KEY_1=gsk_
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_MODEL_PLANNER=llama-3.3-70b-versatile
GROQ_MODEL_NARRATOR=llama-3.3-70b-versatile
GROQ_MODEL_SQL_FALLBACK=llama-3.3-70b-versatile
# Optional: contextual follow-up chips per answer; empty uses GROQ_MODEL_NARRATOR.
GROQ_MODEL_FOLLOWUPS=
FOLLOW_UP_TIMEOUT_MS=10000

# Upload PII scan (server-side). Empty GROQ_MODEL_PII uses GROQ_MODEL_PLANNER.
# PII_AGENT_DISABLED=true forces heuristic redaction only (no Groq calls for PII).
PII_AGENT_DISABLED=false
PII_AGENT_TIMEOUT_MS=45000
GROQ_MODEL_PII=

# Google Gemini — optional narrator; second key optional
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_MODEL=gemini-2.5-flash

# Pipeline
# DISABLE_RESPONSE_CACHE=true — skip response_cache lookup (full pipeline every time; useful for eval reruns)
DISABLE_RESPONSE_CACHE=false
USE_GEMINI_NARRATOR=false # set true to use gemini narrator
SQL_TIER_LOG=false
SNAPSHOT_MODE=false
SQL_FALLBACK_TIMEOUT_MS=3000
SECONDARY_QUERY_DELTA_THRESHOLD=0.05

# Server
PORT=3001
NODE_ENV=development

# CORS: optional comma-separated production origins (e.g. Vercel). Localhost and 127.0.0.1 dev ports are allowed by default.
# CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=
