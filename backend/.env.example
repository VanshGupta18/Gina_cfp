# Copy to .env and fill values. See docs/Backend_Master.md Section 2.

# PostgreSQL (Supabase — Transaction pooler URI recommended; must include user + password in URL)
# npm run migrate loads this file automatically — shell-only $DATABASE_URL is NOT set for npm scripts
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase (JWT verification)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxx

# AWS S3
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_S3_BUCKET=talktodata-uploads
AWS_REGION=eu-west-2

# EC2 SQLCoder endpoint
SQLCODER_EC2_URL=http://127.0.0.1:8080/generate
SQLCODER_EC2_TIMEOUT_MS=3000

# HuggingFace (SQLCoder fallback + embeddings)
HF_API_KEY_1=hf_xxx
HF_API_KEY_2=
SQLCODER_HF_MODEL=defog/sqlcoder-8b
EMBEDDING_HF_MODEL=BAAI/bge-small-en-v1.5

# Groq
GROQ_API_KEY_1=gsk_xxx
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_MODEL_PLANNER=llama-4-scout-17b-16e-instruct
GROQ_MODEL_NARRATOR=llama-4-maverick-17b-128e-instruct
GROQ_MODEL_SQL_FALLBACK=llama-4-maverick-17b-128e-instruct

# Gemini (demo narrator)
GEMINI_API_KEY_1=xxx
GEMINI_API_KEY_2=
GEMINI_MODEL=gemini-2.5-flash

# Pipeline config
USE_GEMINI_NARRATOR=false
SNAPSHOT_MODE=false
SQL_FALLBACK_TIMEOUT_MS=3000
SECONDARY_QUERY_DELTA_THRESHOLD=0.05

# Server
PORT=3001
NODE_ENV=development
